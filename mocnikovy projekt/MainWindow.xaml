<Window x:Class="mocnikovy_projekt.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Útěk z domova" Height="1080" Width="1920" 

        WindowState="Maximized" WindowStyle="None" Background="Black">

    <Grid>

        <Canvas x:Name="MenuScene" Visibility="Visible">

            <Image Source="titstulnistranka.png" Width="1920" Height="1080" Stretch="Fill"/>

            <StackPanel Canvas.Left="760" Canvas.Top="600">

                <Button Content="NOVÁ HRA" Click="StartGame_Click" Width="400" Height="143" FontSize="40" Margin="0,10" Background="#FFE6C391" Cursor="Hand" RenderTransformOrigin="0.5,0.5">

                    <Button.RenderTransform>

                        <TransformGroup>

                            <ScaleTransform/>

                            <SkewTransform AngleX="0.699"/>

                            <RotateTransform/>

                            <TranslateTransform X="0.488"/>

                        </TransformGroup>

                    </Button.RenderTransform>

                </Button>

                <Button Content="NASTAVENÍ" Click="Settings_Click" Width="400" Height="157" FontSize="40" Margin="0,10" Background="#FFE6C391" Cursor="Hand"/>

                <Button Content="KONEC" Click="Exit_Click" Width="400" Height="169" FontSize="40" Margin="0,10" Background="#FFE6C391" Cursor="Hand" RenderTransformOrigin="0.505,1.5"/>

            </StackPanel>

        </Canvas>



        <Canvas x:Name="Scene1" Visibility="Collapsed">

            <Image Source="pokojpenisniotvor.png" Width="1920" Height="1080" Stretch="Fill"/>



            <Rectangle Fill="Transparent" Width="800" Height="300" Canvas.Left="200" Canvas.Top="500" MouseDown="Bed_Click" Cursor="Hand"/>

            <Rectangle Fill="Transparent" Width="180" Height="120" Canvas.Left="180" Canvas.Top="430" MouseDown="Pillow_Click" Cursor="Hand"/>

            <Rectangle Fill="Transparent" Width="450" Height="350" Canvas.Left="1350" Canvas.Top="280" MouseDown="PC_Click" Cursor="Hand"/>

            <Rectangle Fill="Transparent" Width="250" Height="350" Canvas.Left="80" Canvas.Top="600" MouseDown="Cage_Click" Cursor="Hand"/>



            <Rectangle Fill="Transparent" Width="100" Height="1080" Canvas.Left="1820" Canvas.Top="0" MouseDown="GoToBathroom_Click" Cursor="Hand"/>

        </Canvas>



        <Canvas x:Name="Scene2" Visibility="Collapsed">

            <Image Source="/sexvkoupene.png" Width="1920" Height="1080" Stretch="Fill"/>



            <Rectangle Fill="Transparent" Width="900" Height="300" Canvas.Left="950" Canvas.Top="280" MouseDown="Bath_Click" Cursor="Hand"/>

            <Rectangle Fill="Transparent" Width="250" Height="200" Canvas.Left="380" Canvas.Top="280" MouseDown="Cabinet_Click" Cursor="Hand"/>



            <Rectangle x:Name="Tile_Zone" Fill="Transparent" Width="100" Height="100" Canvas.Left="850" Canvas.Top="750" MouseDown="Tile_Click" Cursor="Hand"/>

            <Rectangle x:Name="Safe_Zone" Fill="#88FF0000" Width="120" Height="120" Canvas.Left="840" Canvas.Top="740" Visibility="Collapsed" MouseDown="Safe_Click" Cursor="Hand"/>



            <Rectangle Fill="Transparent" Width="100" Height="1080" Canvas.Left="0" Canvas.Top="0" MouseDown="GoToRoom_Click" Cursor="Hand"/>

        </Canvas>



        <Border x:Name="SettingsPopup" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="200">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="NASTAVENÍ" Foreground="White" FontSize="50" Margin="20"/>

                <CheckBox Content="HUDBA (ON/OFF)" IsChecked="True" FontSize="30" Foreground="White" HorizontalAlignment="Center"/>

                <Button Content="ZAVŘÍT" Click="CloseSettings_Click" Margin="20" Width="200" Height="50" Cursor="Hand"/>

            </StackPanel>

        </Border>



        <Border x:Name="NotificationPanel" Background="Black" Opacity="0.8" Height="120" VerticalAlignment="Top" Visibility="Collapsed" Panel.ZIndex="100">

            <TextBlock x:Name="NotificationText" Foreground="White" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="50,0"/>

        </Border>

    </Grid>

</Window>